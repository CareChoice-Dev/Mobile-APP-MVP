{
  "expo": {
    "name": "CareChoice",
    "slug": "carechoice",
    "scheme": "carechoice",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0E5A8A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.carechoice.mobile"
    },
    "android": {
      "package": "com.carechoice.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
