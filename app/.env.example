# CareChoice mobile app — Supabase connection.
# These EXPO_PUBLIC_* vars are inlined into the JS bundle at build time and are
# safe to ship: the anon key is a PUBLIC key. The per-user security boundary is
# Postgres Row-Level Security (see /supabase/schema.sql), NOT the secrecy of this
# key. Never put the service-role key here.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
