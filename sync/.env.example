# Salesforce — integration user via OAuth 2.0 JWT Bearer (see architecture §3.2).
# For a quick PoC you may instead use a username/password+token session; JWT is
# the production path. jsforce supports both.
SF_LOGIN_URL=https://test.salesforce.com         # test.salesforce.com for sandbox/UAT
SF_CLIENT_ID=                                     # Connected App consumer key
SF_USERNAME=                                      # integration user username
SF_PRIVATE_KEY_PATH=./server.key                  # private key matching the Connected App cert
# --- OR, PoC-only fallback (avoid in production) ---
SF_PASSWORD=                                      # integration user password + security token

# The worker we are syncing for. In the MVP this is seeded manually.
# Default below is the Resource proven against UAT in docs/architecture.md §11.
SF_RESOURCE_ID=a2sI80000000HFPIA2

# Supabase — service role key (server-side only, bypasses RLS).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Set DRY_RUN=1 to log intended writes without creating Salesforce/Supabase records.
DRY_RUN=1
